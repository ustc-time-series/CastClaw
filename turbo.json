  "globalEnv": ["CI", "CASTCLAW_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "CASTCLAW_DISABLE_SHARE"],
  "tasks": {
    "typecheck": {},
    "build": {
      "dependsOn": [],
