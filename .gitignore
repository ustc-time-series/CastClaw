# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
/.venv/
/venv/
/env/
.uv/
*.egg-info/
.eggs/
# Python virtual environments (per-project uv envs)
.python-version
# uv cache
.cache/
# Python tooling caches
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
