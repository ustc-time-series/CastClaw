# ============================================================
# Dependencies
# ============================================================
node_modules/
.pnp
.pnp.js

# ============================================================
# CLI binary artifacts (distributed via GitHub Releases, not git)
# Build with: bun run --cwd packages/castclaw build --single
# ============================================================
packages/castclaw/dist/
packages/castclaw/bin/.castclaw*
# App frontend build artifacts (generated by `bun run build`, not source)
packages/app/dist/



# ============================================================
# Bun
# ============================================================
# bun.lock is intentionally committed for reproducible installs

# ============================================================
# Environment & secrets
# ============================================================
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# ============================================================
# Test fixtures (may contain real data or API keys)
# ============================================================
finaltest/

# ============================================================
# Internal workflow & planning artifacts
# ============================================================
.planning/
.claude/

# ============================================================
